# Настройки S3/MinIO
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=models
MODEL_KEY=model.pkl
TMP_MODEL_PATH=/tmp

# Настройки модели
COMMERCIAL_THRESHOLD=0.5
FALLBACK_THRESHOLD=10000

# Настройки API
DEBUG=true
HOST=0.0.0.0
PORT=8000
CORS_ORIGINS=*

# Настройки логирования
LOG_LEVEL=INFO
SQLALCHEMY_LOG_LEVEL=DEBUG

# Пути к данным
INPUT_DATA_PATH=./test_data.csv
OUTPUT_DATA_PATH=./preds

# Настройки для Airflow (если используется)
PROJECT_ROOT=/app
ADMIN_EMAIL=admin@example.com


# Настройки PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=energy_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/energy_db

# API ключ для Mistral AI
MISTRAL_API_KEY=your_mistral_api_key_here